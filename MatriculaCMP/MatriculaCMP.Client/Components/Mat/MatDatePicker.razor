@namespace MatriculaCMP.Client.Components.Mat

<div class="mat-input-container mat-datepicker-container @(Invalid ? "mat-input-invalid" : "")">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="mat-input-label" for="@Id">
            @Label
            @if (Required) { <span class="mat-input-required">*</span> }
        </label>
    }
    <input type="date"
           id="@Id"
           class="mat-input-field"
           value="@FormatValue(Value)"
           @onchange="OnChange"
           min="@FormatValue(Min)"
           max="@FormatValue(Max)"
           disabled="@Disabled"
           required="@Required"
           aria-invalid="@Invalid" />
    @if (Invalid && !string.IsNullOrEmpty(ErrorMessage))
    {
        <span class="mat-input-error">@ErrorMessage</span>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; } = Guid.NewGuid().ToString("N")[..8];
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public DateTime? Min { get; set; }
    [Parameter] public DateTime? Max { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }

    [Parameter] public DateTime? Value { get; set; }
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }

    private static string? FormatValue(DateTime? d) => d?.ToString("yyyy-MM-dd");

    private async Task OnChange(ChangeEventArgs e)
    {
        var s = e.Value?.ToString();
        Value = DateTime.TryParse(s, out var parsed) ? parsed : null;
        await ValueChanged.InvokeAsync(Value);
    }
}
