@namespace MatriculaCMP.Client.Components.Mat

<div class="mat-input-container @(Invalid ? "mat-input-invalid" : "") @(Disabled ? "mat-input-disabled" : "")">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="mat-input-label" for="@Id">
            @Label
            @if (Required) { <span class="mat-input-required">*</span> }
        </label>
    }
    <input type="@Type"
           id="@Id"
           class="mat-input-field"
           value="@Value"
           @oninput="OnInput"
           placeholder="@Placeholder"
           disabled="@Disabled"
           required="@Required"
           maxlength="@MaxLength"
           aria-invalid="@Invalid"
           aria-describedby="@(Invalid && !string.IsNullOrEmpty(ErrorMessage) ? $"{Id}-error" : null)"
           @attributes="AdditionalAttributes" />
    @if (Invalid && !string.IsNullOrEmpty(ErrorMessage))
    {
        <span class="mat-input-error" id="@(Id)-error">@ErrorMessage</span>
    }
</div>

@code {
    [Parameter] public string? Id { get; set; } = Guid.NewGuid().ToString("N")[..8];
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public int? MaxLength { get; set; }

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? ErrorMessage { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await ValueChanged.InvokeAsync(Value);
    }
}
