@page "/home"
@using MatriculaCMP.Client.Layout
@using MatriculaCMP.Shared
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject HttpClient Http

@if (!string.IsNullOrEmpty(perfilUsuario) && tiles is not null)
{
    @* ---------- Perfil médico (Imagen 1): Bienvenida + tabla proceso + círculo progreso ---------- *@
    @if (perfilUsuario == "2")
    {
        <div class="mat-ficha-page">
            <div class="mat-home-welcome">
                <h1>Bienvenido al Sistema de Matrícula</h1>
                <p>Gestiona tu proceso de colegiatura de manera sencilla</p>
            </div>

            @if (mostrarBotonObservaciones || mostrarBotonRegistrar)
            {
                <div class="d-flex flex-wrap gap-2 mb-4">
                    @if (mostrarBotonObservaciones)
                    {
                        <button type="button" class="btn btn-warning shadow-sm" @onclick="IrACorregirObservacion">
                            <i class="ri-alert-line me-1"></i> Corregir Observación
                        </button>
                    }
                    @if (mostrarBotonRegistrar)
                    {
                        <button type="button" class="btn btn-primary" @onclick="IrARegistro">
                            <i class="ri-add-circle-line me-1"></i> Iniciar Solicitud
                        </button>
                    }
                </div>
            }

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }
            else
            {
                <div class="row g-4">
                    <div class="col-12 col-lg-8">
                        <div class="card shadow-sm border-0 overflow-hidden">
                            <div class="table-responsive">
                                <table class="mat-process-table">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Estado del Proceso</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (estadosResponse?.Estados != null && estadosResponse.Estados.Count > 0)
                                        {
                                            var idx = 1;
                                            var marcadoEnProceso = false;
                                            @foreach (var estado in estadosResponse.Estados)
                                            {
                                                var esActual = !estado.TieneCheck && !marcadoEnProceso;
                                                if (esActual) { marcadoEnProceso = true; }
                                                <tr class="@(esActual ? "mat-row-current" : "")">
                                                    <td>@idx</td>
                                                    <td>@estado.Nombre</td>
                                                    <td>
                                                        @if (estado.TieneCheck)
                                                        {
                                                            <i class="ri-checkbox-circle-fill" style="color: #78276B; font-size: 1.25rem;" aria-hidden="true"></i>
                                                        }
                                                        else if (esActual)
                                                        {
                                                            <span class="mat-badge-en-proceso">En Proceso</span>
                                                        }
                                                        else
                                                        {
                                                            <i class="ri-radio-button-unfill text-secondary" style="font-size: 1.25rem;" aria-hidden="true"></i>
                                                        }
                                                    </td>
                                                </tr>
                                                idx++;
                                            }
                                        }
                                        else
                                        {
                                            <tr><td colspan="3" class="text-center text-muted py-4">No hay estados para mostrar</td></tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-4">
                        <div class="card shadow-sm border-0 p-4 d-flex flex-column align-items-center">
                            @{
                                var pct = (int)Math.Round(estadosResponse?.PorcentajeCompletado ?? 0);
                                var size = 200;
                                var strokeWidth = 16;
                                var radius = (size - strokeWidth) / 2.0;
                                var circumference = radius * 2 * Math.PI;
                                var inv = System.Globalization.CultureInfo.InvariantCulture;
                                var dashArray = pct <= 0 ? "0 " + circumference.ToString("G", inv) : circumference.ToString("G", inv);
                                var strokeLen = pct <= 0 ? 0 : (pct / 100.0) * circumference;
                                var dashOffset = pct <= 0 ? 0 : circumference - strokeLen;
                            }
                            <div class="mat-progress-circle-wrap">
                                <svg width="@size" height="@size" aria-hidden="true" viewBox="0 0 @size @size">
                                    <circle cx="@(size/2)" cy="@(size/2)" r="@radius" stroke="#e5e7eb" stroke-width="@strokeWidth" fill="none" />
                                    <defs>
                                        <linearGradient id="progressGradientHome" x1="0%" y1="0%" x2="100%" y2="0%">
                                            <stop offset="0%" stop-color="#78276B" />
                                            <stop offset="100%" stop-color="#F8AD1D" />
                                        </linearGradient>
                                    </defs>
                                    <circle cx="@(size/2)" cy="@(size/2)" r="@radius" stroke="url(#progressGradientHome)" stroke-width="@strokeWidth"
                                            stroke-dasharray="@(strokeLen.ToString("G", inv)) @(circumference.ToString("G", inv))" stroke-dashoffset="0" stroke-linecap="round" fill="none" />
                                </svg>
                                <div class="mat-progress-circle-text">
                                    <span class="mat-progress-circle-label">Progreso</span>
                                    <span class="mat-progress-circle-value">@pct%</span>
                                </div>
                            </div>
                            <div class="mat-estado-actual">
                                <div class="mat-estado-actual-title">
                                    <span class="mat-estado-actual-dot"></span> Estado Actual
                                </div>
                                <p class="mat-estado-actual-value mb-0">@(estadosResponse?.NombreUltimoEstado ?? "—")</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        @* ---------- Otros perfiles (Imagen 2): Panel + KPI cards + gráfico ---------- *@
        <div class="mat-ficha-page">
            <div class="mat-home-breadcrumb">
                <span class="mat-home-breadcrumb-current">Inicio</span>
            </div>
            <h1 class="mat-home-panel-title">PANEL DE CONTROL - @(perfilNombre?.ToUpperInvariant() ?? "ADMIN")</h1>

            <div class="row g-4 mb-4">
                @foreach (var item in tiles)
                {
                    <div class="col-12 col-sm-6 col-xl-4">
                        <div class="mat-kpi-card d-flex align-items-center justify-content-between">
                            <div>
                                <p class="mat-kpi-title mb-0">@item.titulo</p>
                                <p class="mat-kpi-value mb-0">@item.valor</p>
                            </div>
                            <div class="mat-kpi-icon-wrap" style="background-color: @(GetTileIconBg(item.color));">
                                <i class="@item.icono" style="color: @(GetTileIconColor(item.color));" aria-hidden="true"></i>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h2 class="mat-chart-card-title">Estadísticas de Solicitudes por Mes</h2>
                    <div id="estados-mensuales-chart" class="apex-charts" style="min-height: 320px;"></div>
                    @if (totalesPorEstado != null && totalesPorEstado.Count > 0)
                    {
                        <div class="mt-3">
                            <h6 class="text-muted">Suma por estados (año actual)</h6>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var kv in totalesPorEstado)
                                {
                                    <span class="badge bg-secondary">@kv.Key: @kv.Value</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <div class="spinner-border text-info me-2" role="status"><span class="visually-hidden">Cargando...</span></div>
        Cargando...
    </div>
}

@code {
    private string perfilUsuario = "";
    private string perfilNombre = "";
    private string PersonaId = "";
    private List<DashboardTileDto>? tiles;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    private EstadoSolicitudConCheckResponse? estadosResponse;
    private Dictionary<string, int> totalesPorEstado = new();
    private bool adminChartRendered = false;
    private bool mostrarBotonRegistrar = false;
    private bool mostrarBotonObservaciones = false;
    private int solicitudObservadaId = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                perfilUsuario = user.FindFirst("PerfilId")?.Value ?? "1";
                perfilNombre = user.FindFirst("PerfilNombre")?.Value ?? "";
                PersonaId = user.FindFirst("PersonaId")?.Value ?? "-";

                await CargarTiles();
                if (perfilUsuario == "2")
                {
                    await CargarTablaMedico();
                    StateHasChanged();
                }
                else
                {
                    await RenderizarGraficoEstadosMensualesAdmin();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error inicial: {ex.Message}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(perfilUsuario) && perfilUsuario != "2" && !adminChartRendered)
        {
            adminChartRendered = true;
            await RenderizarGraficoEstadosMensualesAdmin();
        }
    }

    private async Task CargarTablaMedico()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            if (int.TryParse(PersonaId, out int personaId))
            {
                var solicitudesActivas = await Http.GetFromJsonAsync<List<SolicitudSeguimientoDto>>(
                    $"api/personaseducacion/mis-solicitudes/{personaId}") ?? new List<SolicitudSeguimientoDto>();

                var solicitudObservada = solicitudesActivas.FirstOrDefault(s => s.EstadoId == 3 || s.EstadoId == 5 || s.EstadoId == 7);
                if (solicitudObservada != null)
                {
                    mostrarBotonObservaciones = true;
                    solicitudObservadaId = solicitudObservada.Id;
                    mostrarBotonRegistrar = false;
                }
                else
                {
                    mostrarBotonObservaciones = false;
                    solicitudObservadaId = 0;
                    mostrarBotonRegistrar = !solicitudesActivas.Any(s => s.EstadoId != 13);
                }

                estadosResponse = await Http.GetFromJsonAsync<EstadoSolicitudConCheckResponse>(
                    $"api/personaseducacion/EstadosConCheck/{personaId}?vistaSimplificada=true");

                if (estadosResponse != null)
                {
                    await RenderizarGraficoEstadosMensuales();
                }
            }
            else
            {
                errorMessage = "ID de persona no válido";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar los estados: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CargarTiles()
    {
        try
        {
            int? persona = int.TryParse(PersonaId, out var pid) ? pid : null;
            var url = $"api/dashboard/resumen?perfilId={perfilUsuario}" + (persona.HasValue ? $"&personaId={persona.Value}" : "");
            tiles = await Http.GetFromJsonAsync<List<DashboardTileDto>>(url) ?? new List<DashboardTileDto>();
        }
        catch
        {
            tiles = new List<DashboardTileDto>();
        }
    }

    private async Task RenderizarGraficoEstadosMensuales()
    {
        try
        {
            if (!int.TryParse(PersonaId, out int personaId) || estadosResponse == null) return;

            var mesesCategorias = new List<string> { "Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic" };
            var mapaPorEstado = new Dictionary<string, int[]>(StringComparer.OrdinalIgnoreCase);
            foreach (var e in estadosResponse.Estados)
                mapaPorEstado[e.Nombre] = new int[12];

            var solicitudes = await Http.GetFromJsonAsync<List<SolicitudSeguimientoDto>>($"api/personaseducacion/mis-solicitudes/{personaId}") ?? new List<SolicitudSeguimientoDto>();
            var anioActual = DateTime.Now.Year;
            foreach (var s in solicitudes)
            {
                if (s.FechaSolicitud.Year != anioActual) continue;
                var mesIndex = s.FechaSolicitud.Month - 1;
                var estado = estadosResponse.Estados.FirstOrDefault(x => x.Id == s.EstadoId);
                if (estado != null)
                    mapaPorEstado[estado.Nombre][mesIndex]++;
            }

            var estadosOrdenados = estadosResponse.Estados.OrderBy(e => e.Id).ToList();
            var seriesApiLocal = await Http.GetFromJsonAsync<List<EstadoMesSerieDto>>($"api/personaseducacion/series-estados-mes?personaId={personaId}&anio={anioActual}") ?? new List<EstadoMesSerieDto>();
            var series = new List<object>();
            foreach (var e in estadosOrdenados)
            {
                var match = seriesApiLocal.FirstOrDefault(s => s.EstadoId == e.Id);
                series.Add(new { name = e.Nombre, data = match?.Meses ?? (mapaPorEstado.TryGetValue(e.Nombre, out var arr) ? arr : new int[12]) });
            }

            totalesPorEstado = mapaPorEstado.ToDictionary(k => k.Key, v => v.Value.Sum());
            var colores = estadosOrdenados.Select(e => ColorPorEstado(e.Id)).ToArray();
            var totalLinea = new int[12];
            foreach (dynamic s in series)
            {
                int[] data = s.data;
                for (int i = 0; i < 12; i++) totalLinea[i] += data[i];
            }
            await JS.InvokeVoidAsync("renderEstadosMixto", series, totalLinea, mesesCategorias, colores);
        }
        catch { /* gráfico médico opcional */ }
    }

    private async Task RenderizarGraficoEstadosMensualesAdmin()
    {
        try
        {
            var solicitudes = await Http.GetFromJsonAsync<List<SolicitudSeguimientoDto>>("api/personaseducacion/solicitudesdets") ?? new List<SolicitudSeguimientoDto>();
            var mesesCategorias = new List<string> { "Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic" };
            var mapaPorEstado = new Dictionary<string, int[]>(StringComparer.OrdinalIgnoreCase);

            var estadosCatalogoResp = await Http.GetFromJsonAsync<EstadoSolicitudConCheckResponse>("api/personaseducacion/EstadosConCheck/0");
            var estadosCatalogo = estadosCatalogoResp?.Estados ?? new List<EstadoSolicitudConCheckDto>();
            foreach (var e in estadosCatalogo.OrderBy(e => e.Id))
            {
                if (!mapaPorEstado.ContainsKey(e.Nombre))
                    mapaPorEstado[e.Nombre] = new int[12];
            }

            var anioActual = DateTime.Now.Year;
            foreach (var s in solicitudes)
            {
                if (s.FechaSolicitud.Year != anioActual) continue;
                var mesIndex = s.FechaSolicitud.Month - 1;
                var estadoNombre = string.IsNullOrWhiteSpace(s.Estado) ? "Sin Estado" : s.Estado;
                if (!mapaPorEstado.TryGetValue(estadoNombre, out var arr))
                {
                    arr = new int[12];
                    mapaPorEstado[estadoNombre] = arr;
                }
                arr[mesIndex]++;
            }

            List<object> series = estadosCatalogo.Any()
                ? estadosCatalogo.OrderBy(e => e.Id).Select(e => new { name = e.Nombre, data = mapaPorEstado.TryGetValue(e.Nombre, out var arr) ? arr : new int[12] }).Cast<object>().ToList()
                : mapaPorEstado.OrderBy(k => k.Key).Select(kvp => new { name = kvp.Key, data = kvp.Value }).Cast<object>().ToList();

            totalesPorEstado = mapaPorEstado.ToDictionary(k => k.Key, v => v.Value.Sum());
            StateHasChanged();

            var colores = (estadosCatalogo.Any()
                ? estadosCatalogo.OrderBy(e => e.Id).Select(e => ColorPorEstado(e.Id))
                : mapaPorEstado.Keys.OrderBy(k => k).Select(_ => "#1cbb8c")).ToArray();
            var totalLineaAdm = new int[12];
            foreach (dynamic s in series)
            {
                int[] data = s.data;
                for (int i = 0; i < 12; i++) totalLineaAdm[i] += data[i];
            }
            await JS.InvokeVoidAsync("renderEstadosMixto", series, totalLineaAdm, mesesCategorias, colores);
        }
        catch { }
    }

    private static string GetTileIconBg(string color)
    {
        return color?.ToLowerInvariant() switch
        {
            "primary" => "#78276B20",
            "warning" => "#F59E0B20",
            "success" => "#10B98120",
            "info" => "#3B82F620",
            "dark" => "#37415120",
            _ => "#6b728020"
        };
    }

    private static string GetTileIconColor(string color)
    {
        return color?.ToLowerInvariant() switch
        {
            "primary" => "#78276B",
            "warning" => "#F59E0B",
            "success" => "#10B981",
            "info" => "#3B82F6",
            "dark" => "#374151",
            _ => "#6b7280"
        };
    }

    private static string ColorPorEstado(int id)
    {
        return id switch
        {
            1 => "#2563EB",
            2 => "#F59E0B",
            3 => "#EF4444",
            4 => "#10B981",
            5 => "#B91C1C",
            6 => "#FB923C",
            7 => "#7F1D1D",
            8 => "#3B82F6",
            9 => "#06B6D4",
            10 => "#6366F1",
            11 => "#0EA5E9",
            _ => "#5664d2"
        };
    }

    private void IrARegistro() => Navigation.NavigateTo("/solicitudes/prematricula");
    private void IrACorregirObservacion()
    {
        if (solicitudObservadaId > 0)
            Navigation.NavigateTo($"/solicitudes/prematricula/{solicitudObservadaId}");
    }
}
