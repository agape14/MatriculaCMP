@page "/solicitudes/prematricula"
@page "/solicitudes/prematricula/{SolicitudId:int}"
@using MatriculaCMP.Client.Services
@using System.Net.Http.Headers;
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using MatriculaCMP.Shared
@using System.Text.Json
@using System.IO
@using System.Threading


@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject HttpClient Http
@inject AuthenticationStateProvider AuthenticationStateProvider

<!-- Botón flotante para ver observaciones -->
@if (esCorreccionPorObservacion && !mostrarObservaciones)
{
	<button type="button" class="btn btn-warning position-fixed shadow" 
			style="bottom: 20px; right: 20px; z-index: 1000; border-radius: 50px;"
			@onclick="() => mostrarObservaciones = true">
		<i class="ri-alert-line me-1"></i>
		<span class="d-none d-md-inline">Ver Observaciones</span>
		<span class="d-inline d-md-none">⚠️</span>
	</button>
}

<!-- Modal para mostrar observaciones -->
@if (mostrarObservaciones)
{
	<div class="modal fade show" style="display: block; position: fixed; inset: 0; z-index: 1055;" tabindex="-1">
		<div class="modal-backdrop fade show" style="position: fixed; inset: 0; z-index: 1050; background-color: rgba(0,0,0,0.5);" @onclick="CerrarObservaciones"></div>
		<div class="modal-dialog modal-lg" style="position: relative; z-index: 1056;">
			<div class="modal-content">
				<div class="modal-header bg-warning text-dark">
					<h5 class="modal-title">
						⚠️ Observaciones de la Solicitud
					</h5>
					<button type="button" class="btn-close" @onclick="CerrarObservaciones"></button>
				</div>
				<div class="modal-body">
					<div class="alert alert-warning">
						<h6><strong>Estado Actual:</strong> @estadoActual</h6>
						<p><strong>Observaciones:</strong></p>
						<div class="border p-3 bg-light">
							@observacionesSolicitud
						</div>
					</div>
					<div class="alert alert-info">
						<p><strong>Instrucciones:</strong></p>
						<ul>
							<li>Revise cuidadosamente las observaciones indicadas</li>
							<li>Corrija los campos que necesiten ajustes</li>
							<li>Una vez corregido, guarde los cambios</li>
							<li>Después de guardar, regrese al listado y haga clic en "Reenviar"</li>
						</ul>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" @onclick="CerrarObservaciones">Cerrar</button>
					<button type="button" class="btn btn-primary" @onclick="CerrarObservaciones">Entendido</button>
				</div>
			</div>
		</div>
	</div>
}

@* Modal Requisitos previos (estilo alineado a RegistrationView: línea morada solo arriba, icono amarillo, texto limpio) *@
@if (showInfoModal && currentStep == 1 && SolicitudId <= 0 && !esCorreccionPorObservacion)
{
	<div class="modal fade show mat-modal-requisitos" style="display: block; position: fixed; inset: 0; z-index: 1055;" tabindex="-1" aria-labelledby="modalRequisitosTitle" aria-modal="true" role="dialog">
		<div class="modal-backdrop fade show" style="position: fixed; inset: 0; z-index: 1050; background-color: rgba(0,0,0,0.5);" @onclick="CerrarModalRequisitos"></div>
		<div class="modal-dialog modal-dialog-centered" style="position: relative; z-index: 1056;">
			<div class="modal-content mat-modal-requisitos-content">
				<div class="modal-header mat-modal-requisitos-header">
					<button type="button" class="btn-close position-absolute top-0 end-0 m-3" aria-label="Cerrar" @onclick="CerrarModalRequisitos"></button>
				</div>
				<div class="modal-body mat-modal-requisitos-body">
					<div class="d-flex justify-content-center mb-4">
						<div class="mat-modal-requisitos-icon rounded-circle d-flex align-items-center justify-content-center">
							<i class="ri-information-line" aria-hidden="true"></i>
						</div>
					</div>
					<h2 class="mat-modal-requisitos-title text-center mb-4" id="modalRequisitosTitle">Requisitos previos para el registro</h2>
					<p class="mat-modal-requisitos-intro">Antes de iniciar el registro, asegúrese de tener:</p>
					<ul class="mat-modal-requisitos-list list-unstyled mb-0">
						<li class="d-flex gap-2 mb-2"><span class="mat-modal-requisitos-bullet">•</span><span><strong>DNI electrónico:</strong> Necesario para validar su DDJJ mediante ID PERU.</span></li>
						<li class="d-flex gap-2 mb-2"><span class="mat-modal-requisitos-bullet">•</span><span><strong>Paso 2 - Curso de Ética:</strong> Debe completar el curso en el Aula Virtual antes de continuar al paso 3.</span></li>
						<li class="d-flex gap-2 mb-2"><span class="mat-modal-requisitos-bullet">•</span><span><strong>Paso 4 - Pago:</strong> Debe realizar el pago correspondiente para enviar su solicitud.</span></li>
						<li class="d-flex gap-2 mb-2"><span class="mat-modal-requisitos-bullet">•</span><span><strong>Documentos:</strong> Tenga a mano su título profesional, constancias y demás documentos escaneados en formato PDF.</span></li>
						<li class="d-flex gap-2 mb-2"><span class="mat-modal-requisitos-bullet">•</span><span><strong>Foto reciente:</strong> Para cargar en el formulario (formato válido, buena calidad).</span></li>
					</ul>
					<p class="mat-modal-requisitos-disclaimer">Esta información es solo de carácter informativo.</p>
				</div>
				<div class="modal-footer mat-modal-requisitos-footer">
					<button type="button" class="btn mat-modal-requisitos-btn w-100" @onclick="CerrarModalRequisitos">Entendido</button>
				</div>
			</div>
		</div>
	</div>
}

<div class="mat-ficha-page">
	<div class="card">
		<div class="card-body">
	<!-- Breadcrumb -->
	<nav class="mat-ficha-breadcrumb" aria-label="Miga de pan">
		<a href="/home">Inicio</a>
		<span> &gt; </span>
		<span>Ficha Pre-matrícula</span>
	</nav>

	<!-- Título e icono (diseño Imagen 2) -->
	<div class="mat-ficha-header">
		<div class="mat-ficha-header-icon">
			<i class="ri-profile-line" aria-hidden="true"></i>
		</div>
		<div>
			<h1 class="mat-ficha-title">FICHA PRE-MATRÍCULA</h1>
			<p class="mat-ficha-subtitle">Complete los datos requeridos para su inscripción</p>
		</div>
	</div>

	@* Callout Consulta Es Médico *@
	@if (mostrarCalloutEsMedico)
	{
		<div class="mb-3 @(resultadoEsMedico == true ? "bd-callout bd-callout-danger" : "bd-callout bd-callout-info")">
			<strong>@(resultadoEsMedico == true ? "⚠️ Atención:" : "ℹ️ Información:")</strong>
			@mensajeConsultaMedico
		</div>
	}

	<!-- Stepper (diseño imagen: card, iconos grandes, líneas conectoras, Paso X/5) -->
	<div class="mat-stepper-card">
		<div class="mat-stepper-inner">
			<div class="mat-stepper-step-wrap">
				<div class="mat-stepper-step @StepClass(1)">
					<span class="mat-stepper-circle">
						@if (ShouldShowCheck(1)) { <i class="ri-check-line" aria-hidden="true"></i> } else { <i class="ri-user-line" aria-hidden="true"></i> }
					</span>
					<span class="mat-stepper-label">Registro</span>
					@if (currentStep == 1) { <span class="mat-stepper-pill">Paso 1/5</span> }
				</div>
				<div class="mat-stepper-connector @(1 < currentStep ? "completed" : "pending")"></div>
			</div>
			<div class="mat-stepper-step-wrap">
				<div class="mat-stepper-step @StepClass(2)">
					<span class="mat-stepper-circle">
						@if (ShouldShowCheck(2)) { <i class="ri-newspaper-line" aria-hidden="true"></i> } else { <i class="ri-newspaper-line" aria-hidden="true"></i> }
					</span>
					<span class="mat-stepper-label">Ética</span>
					@if (currentStep == 2) { <span class="mat-stepper-pill">Paso 2/5</span> }
				</div>
				<div class="mat-stepper-connector @(2 < currentStep ? "completed" : "pending")"></div>
			</div>
			<div class="mat-stepper-step-wrap">
				<div class="mat-stepper-step @StepClass(3)">
					<span class="mat-stepper-circle">
						@if (ShouldShowCheck(3)) { <i class="ri-check-line" aria-hidden="true"></i> } else { <i class="ri-checkbox-circle-line" aria-hidden="true"></i> }
					</span>
					<span class="mat-stepper-label">Validación</span>
					@if (currentStep == 3) { <span class="mat-stepper-pill">Paso 3/5</span> }
				</div>
				<div class="mat-stepper-connector @(3 < currentStep ? "completed" : "pending")"></div>
			</div>
			<div class="mat-stepper-step-wrap">
				<div class="mat-stepper-step @StepClass(4)">
					<span class="mat-stepper-circle">
						@if (ShouldShowCheck(4)) { <i class="ri-check-line" aria-hidden="true"></i> } else { <i class="ri-bank-card-line" aria-hidden="true"></i> }
					</span>
					<span class="mat-stepper-label">Pago</span>
					@if (currentStep == 4) { <span class="mat-stepper-pill">Paso 4/5</span> }
				</div>
				<div class="mat-stepper-connector @(4 < currentStep ? "completed" : "pending")"></div>
			</div>
			<div class="mat-stepper-step-wrap">
				<div class="mat-stepper-step @StepClass(5)">
					<span class="mat-stepper-circle">
						@if (ShouldShowCheck(5)) { <i class="ri-check-line" aria-hidden="true"></i> } else { <i class="ri-send-plane-line" aria-hidden="true"></i> }
					</span>
					<span class="mat-stepper-label">Solicitud enviada</span>
					@if (currentStep == 5) { <span class="mat-stepper-pill">Paso 5/5</span> }
				</div>
			</div>
		</div>
	</div>

	<!-- Alerta importante (Imagen 2) -->
	<div class="mat-ficha-alert">
		<i class="ri-error-warning-line" aria-hidden="true"></i>
		<div class="mat-ficha-alert-content">
			<strong>Importante:</strong> Los campos marcados con <span style="color: var(--mat-destructive);">*</span> son obligatorios. Su perfil profesional determinará los requisitos específicos del curso de Ética.
		</div>
	</div>

	@* Carga inicial: solo el área de contenido muestra spinner, sin bloquear la vista del menú/stepper *@
	@if (charging)
	{
		<div class="card border-0 shadow-sm rounded-3 py-5 my-3">
			<div class="card-body text-center">
				<div class="spinner-border text-primary" role="status" aria-hidden="true"></div>
				<p class="mt-2 text-muted mb-0">Cargando datos...</p>
			</div>
		</div>
	}
	else
	{
	@* Banner de observaciones si viene de corrección *@
							@if (esCorreccionPorObservacion)
							{
								<div class="alert alert-warning d-flex align-items-start mb-3">
									<div class="me-2">⚠️</div>
									<div class="flex-grow-1">
										<div class="fw-bold">Esta solicitud tiene observaciones</div>
										<div class="small">Revise y corrija los campos indicados según las observaciones del revisor.</div>
									</div>
									<button type="button" class="btn btn-sm btn-outline-warning" @onclick="() => mostrarObservaciones = true">
										<i class="ri-eye-line"></i> Ver Observaciones
									</button>
								</div>
							}

							@* PASO 1: Registro inicial (con secciones alineadas al diseño: Paso 1, 2, 3) *@
							@if (currentStep == 1)
							{
								@* Paso 1: Selección de Perfil *@
								<div class="card shadow-sm border-2 mb-3" style="border-color: var(--mat-primary);">
									<div class="mat-ficha-step-header">
										<div class="mat-ficha-step-header-icon"><i class="ri-user-line" aria-hidden="true"></i></div>
										<div>
											<h3 class="mat-ficha-step-header-title">Paso 1: Selección de Perfil</h3>
											<p class="mat-ficha-step-header-subtitle">Seleccione su perfil profesional y consejo regional</p>
										</div>
									</div>
									<div class="card-body">
								<div class="row">
									<div class="col-md-6">
										<div class="form-group">
											<label class="fw-bold">Seleccione su perfil *</label>
											<InputSelect TValue="string"
														 Value="@perfilSeleccionado"
														 ValueChanged="@((string val) => OnPerfilSeleccionado(val))"
														 ValueExpression="@(() => perfilSeleccionado)"
														 class="@($"form-control {(string.IsNullOrWhiteSpace(perfilSeleccionado) && intentadoEnviar ? "is-invalid" : "")}")">
												<option value="">Seleccione su perfil profesional</option>
												<option value="1">1. Profesional peruano con título de universidad peruana</option>
												<option value="2">2. Profesional peruano con título de universidad extranjera</option>
												<option value="3">3. Profesional extranjero con título otorgado en el Perú</option>
												<option value="4">4. Profesional extranjero con título otorgado en el extranjero</option>
											</InputSelect>
											@if (string.IsNullOrWhiteSpace(perfilSeleccionado) && intentadoEnviar)
											{
												<div class="invalid-feedback d-block">Seleccione un perfil.</div>
											}
											<p class="small text-muted mt-1 mb-0 d-flex align-items-start gap-1">
												<i class="ri-information-line mt-0 pt-1" style="font-size: 1rem;" aria-hidden="true"></i>
												<span>El perfil guía los requisitos del curso de Ética y la documentación necesaria.</span>
											</p>
										</div>
									</div>
									<div class="col-md-6">
										<div class="form-group">
											<label for="lblConsejoRegional">Consejo Regional *</label>
											<InputSelect @bind-Value="formData.ConsejoRegional" class="@($"form-control {(EsConsejoInvalido() && intentadoEnviar ? "is-invalid" : "")}")" id="cbxConsejoRegional" requiered>
												<option value="">Seleccione su consejo regional</option>
												@foreach (var consejo in consejos)
												{
													<option value="@consejo.ConsejoRegional_Key">@consejo.Nombre</option>
												}
											</InputSelect>
											@if (EsConsejoInvalido() && intentadoEnviar)
											{
												<div class="invalid-feedback d-block">Seleccione Consejo Regional.</div>
											}
										</div>
									</div>
								</div>
									</div>
								</div>

								@* Paso 2: Datos Personales *@
								<div class="card shadow-sm border rounded mb-3">
									<div class="mat-ficha-step-header">
										<div class="mat-ficha-step-header-icon"><i class="ri-user-line" aria-hidden="true"></i></div>
										<h3 class="mat-ficha-step-header-title mb-0">Paso 2: Datos Personales</h3>
									</div>
									<div class="card-body border-top-0">
									<div class="row">
										<div class="col-md-4">
													<div class="form-group">
														<label for="td">Tipo de Documento *</label>
														<InputSelect TValue="string"
																	 Value="@formData.TipoDocumento"
																	 ValueChanged="@((string val) => OnTipoDocSeleccionado(val))"
																	 ValueExpression="@(() => formData.TipoDocumento)"
																	 class="@($"form-control {(string.IsNullOrWhiteSpace(formData.TipoDocumento) && intentadoEnviar ? "is-invalid" : "")}")">
															<option value="">Seleccione Tipo de Documento</option>
															@foreach (var td in tipodoc)
															{
																<option value="@td.MaestroRegistro_Key.ToString()">@td.Nombre</option>
															}
														</InputSelect>
														@if (string.IsNullOrWhiteSpace(formData.TipoDocumento) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Seleccione tipo de documento.</div>
														}
													</div>
												</div>
												<div class="col-md-4">
													<div class="form-group">
														<label for="nd">Número de Documento *</label>
														<InputText @bind-Value="formData.NumeroDocumento" class="@($"form-control {(string.IsNullOrWhiteSpace(formData.NumeroDocumento) && intentadoEnviar ? "is-invalid" : "")}")" id="nd" placeholder="Ej: 12345678" @onblur="OnNumeroDocumentoBlur" disabled="@consultandoReniec" />
														@if (string.IsNullOrWhiteSpace(formData.NumeroDocumento) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Ingrese número de documento.</div>
														}
														@if (consultandoReniec)
														{
															<small class="text-muted"><span class="spinner-border spinner-border-sm" role="status"></span> Consultando RENIEC…</small>
														}
													</div>
												</div>
												<div class="col-md-4">
													<div class="form-group">
														<label for="gs">Grupo Sanguineo *</label>
														<InputSelect @bind-Value="formData.GrupoSanguineo" class="@($"form-control {(string.IsNullOrWhiteSpace(formData.GrupoSanguineo) && intentadoEnviar ? "is-invalid" : "")}")" id="gs">
															<option value="">Seleccione...</option>
															@foreach (var gs in gruposang)
															{
																<option value="@gs.MaestroRegistro_Key">@gs.Nombre</option>
															}
														</InputSelect>
														@if (string.IsNullOrWhiteSpace(formData.GrupoSanguineo) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Seleccione grupo sanguíneo.</div>
														}
													</div>
												</div>
												<div class="col-md-4">
													<div class="form-group">
														<label for="nombres">Nombres Completos *</label>
														<InputText @bind-Value="formData.Nombres" class="@($"form-control {(string.IsNullOrWhiteSpace(formData.Nombres) && intentadoEnviar ? "is-invalid" : "")}")" id="nombres" placeholder="Ej: Juan Carlos" requiered />
														@if (string.IsNullOrWhiteSpace(formData.Nombres) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Ingrese nombres.</div>
														}
													</div>
												</div>
												<div class="col-md-4">
													<div class="form-group">
														<label for="apaterno">Apellido Paterno *</label>
														<InputText @bind-Value="formData.ApellidoPaterno" class="@($"form-control {(string.IsNullOrWhiteSpace(formData.ApellidoPaterno) && intentadoEnviar ? "is-invalid" : "")}")" id="apaterno" placeholder="Ej: Pérez" requiered />
														@if (string.IsNullOrWhiteSpace(formData.ApellidoPaterno) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Ingrese apellido paterno.</div>
														}
													</div>
												</div>
												<div class="col-md-4">
													<div class="form-group">
														<label for="amaterno">Apellido Materno *</label>
														<InputText @bind-Value="formData.ApellidoMaterno" class="@($"form-control {(string.IsNullOrWhiteSpace(formData.ApellidoMaterno) && intentadoEnviar ? "is-invalid" : "")}")" id="amaterno" placeholder="Ej: García" requiered />
														@if (string.IsNullOrWhiteSpace(formData.ApellidoMaterno) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Ingrese apellido materno.</div>
														}
													</div>
												</div>

												<div class="col-md-6">
													<div class="form-group">
														<label for="sexo">Sexo *</label>
														<InputSelect @bind-Value="formData.Sexo" class="@($"form-control {(string.IsNullOrWhiteSpace(formData.Sexo) && intentadoEnviar ? "is-invalid" : "")}")" id="sexo">
															<option value="">Seleccione...</option>
															<option value="1">Masculino</option>
															<option value="0">Femenino</option>
														</InputSelect>
														@if (string.IsNullOrWhiteSpace(formData.Sexo) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Seleccione sexo.</div>
														}
													</div>
												</div>
												<div class="col-md-6">
													<div class="form-group">
														<label for="ec">Estado Civil *</label>
														<InputSelect @bind-Value="formData.EstadoCivil" class="@($"form-control {(string.IsNullOrWhiteSpace(formData.EstadoCivil) && intentadoEnviar ? "is-invalid" : "")}")" id="ec">
															<option value="">Seleccione...</option>
															@foreach (var ec in estacivil)
															{
																<option value="@ec.MaestroRegistro_Key">@ec.Nombre</option>
															}
														</InputSelect>
														@if (string.IsNullOrWhiteSpace(formData.EstadoCivil) && intentadoEnviar)
														{
															<div class="invalid-feedback d-block">Seleccione estado civil.</div>
														}
													</div>
												</div>

												@* Carnet de Extranjería: pedir PDF escaneado y mostrar ejemplo *@
												@if (tipoDocSeleccionado == "64")
												{
													<div class="col-12 mt-2">
														<div class="alert alert-info d-flex align-items-start mb-2" role="alert">
															<span class="me-2">ℹ️</span>
															<div>
																<strong>Ejemplo de cómo cargar el PDF:</strong> escaneado de ambas caras del carnet de extranjería.
															</div>
														</div>
														<div class="form-group">
															<label class="fw-bold">Carnet de Extranjería – PDF escaneado *</label>
															<div class="input-group">
																<div class="custom-file" style="flex-grow: 1;">
																	<InputFile @bind-Value="formData.CarnetExtranjeriaPath" OnChange="@(async e => await OnFileSelected(e, nameof(formData.CarnetExtranjeriaPath)))" class="custom-file-input form-control" accept=".pdf" />
																	<label class="custom-file-label form-control">@(pdfCarnetExtranjeria != null ? pdfCarnetExtranjeria.Name : "Seleccione PDF (ambas caras del carnet)")</label>
																</div>
															</div>
														</div>
													</div>
												}
											</div>
									</div>
								</div>

								@* Paso 3: Datos de Universidad *@
								<div class="card mt-3 shadow-sm border rounded">
									<div class="mat-ficha-step-header">
										<div class="mat-ficha-step-header-icon"><i class="ri-slideshow-2-line" aria-hidden="true"></i></div>
										<h3 class="mat-ficha-step-header-title mb-0">Paso 3: Datos de Universidad</h3>
									</div>
									<div class="card-body border-top-0">
										<div class="row">
