											{
												<span class="text-muted small">(@fechaFirmaDDJJ.Value.ToString("dd/MM/yyyy HH:mm"))</span>
											}
										</div>
										<button type="button" class="btn btn-sm btn-outline-success ms-auto" @onclick="DescargarDDJJFirmada">
											<i class="ri-download-line me-1"></i> Descargar PDF
										</button>
									</div>
								}
								<div class="mat-prema-check-item">
