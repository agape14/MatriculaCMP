															}
														</div>
													</div>
													@if (tipoValidacionExtranjera == "reconocimiento")
													{
														<div class="col-md-6">
															<div class="form-group">
																<label>Resolución de Reconocimiento Universidad Nacional *</label>
																<InputText @bind-Value="formData.NumeroResolucion" class="form-control" />
															</div>
														</div>
														<div class="col-md-6">
															<div class="form-group">
																<label>Fecha de reconocimiento *</label>
																<InputDate TValue="DateTime?" @bind-Value="formData.FechaReconocimiento" class="form-control" />
															</div>
														</div>
													}
													else if (tipoValidacionExtranjera == "revalidacion")
													{
														<div class="col-md-6">
															<div class="form-group">
																<label>Resolución de Revalidación Universidad Nacional *</label>
																<InputText @bind-Value="formData.NumeroResolucion" class="form-control" />
															</div>
														</div>
														<div class="col-md-6">
															<div class="form-group">
																<label>Universidad Peruana *</label>
																<InputSelect @bind-Value="formData.UniversidadPeruana" class="form-control">
																	<option value="">Seleccione universidad</option>
																	@foreach (var uniper in universidadesperuanas)
																	{
																		<option value="@uniper.Id">@uniper.Nombre</option>
																	}
																</InputSelect>
															</div>
														</div>
														<div class="col-md-6">
															<div class="form-group">
																<label>Fecha de revalidación *</label>
																<InputDate TValue="DateTime?" @bind-Value="formData.FechaRevalidacion" class="form-control" />
															</div>
														</div>
													}
												}
											</div>
										</div>
									</div>

								<div class="mat-ficha-actions">
									@if (esCorreccionPorObservacion)
									{
										<button type="button" class="btn btn-outline-secondary btn-lg" @onclick='() => Navigation.NavigateTo("/home", forceLoad: true)'>Cancelar</button>
										<button type="button" class="btn btn-primary btn-lg" style="background-color: var(--mat-primary);" @onclick="() => currentStep = 3">
											<span>Siguiente</span>
											<i class="ri-arrow-right-line ms-2" aria-hidden="true"></i>
										</button>
									}
									else
									{
										<button type="button" class="btn btn-outline-secondary btn-lg border-2" @onclick='() => Navigation.NavigateTo("/home", forceLoad: true)'>Cancelar</button>
										<button type="button" class="btn btn-primary btn-lg btn-action" style="background-color: var(--mat-primary);" disabled="@isSavingInicial" @onclick="RegistrarInicialAsync">
											@if (isSavingInicial)
											{
												<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
												<span class="ms-2">Registrando...</span>
											}
											else
											{
												<span>Siguiente</span>
												<i class="ri-arrow-right-line ms-2" aria-hidden="true"></i>
											}
										</button>
									}
								</div>
							}

							@* PASO 2: Curso de Ética (diseño como RegistrationView e imagen) *@
							@if (currentStep == 2)
							{
								<div class="card shadow-sm border-0 overflow-hidden mb-0">
									<div class="mat-ficha-step-header">
										<div class="mat-ficha-step-header-icon"><i class="ri-newspaper-line" aria-hidden="true"></i></div>
										<h3 class="mat-ficha-step-header-title mb-0">Curso de Ética</h3>
									</div>
									<div class="card-body p-4 p-md-6">
										<div class="text-center mb-4">
											<div class="mat-ethics-icon-circle mx-auto mb-3">
												<i class="ri-newspaper-line" aria-hidden="true"></i>
											</div>
											<h4 class="mat-ethics-title mb-2">Complete el Curso de Ética</h4>
											<p class="mat-ethics-desc text-muted mb-0">
												Para continuar con el proceso de pre-matrícula, debe completar el curso de ética en nuestra plataforma de Aula Virtual.
												Una vez que haya finalizado el curso al 100%, podrá avanzar al siguiente paso.
											</p>
										</div>
										@if (avanceCursoPorcentaje > 0)
										{
											<div class="mat-ethics-progress-wrap mx-auto mb-4">
												<div class="d-flex justify-content-between align-items-center mb-2">
													<span class="small fw-medium text-secondary">Progreso del curso</span>
													<span class="small fw-bold" style="color: @(avanceCursoPorcentaje >= 100 ? "var(--mat-success)" : "var(--mat-accent)")">@(avanceCursoPorcentaje >= 100 ? 100 : avanceCursoPorcentaje)%</span>
												</div>
												<div class="progress mat-ethics-progress-bar">
													<div class="progress-bar" role="progressbar" style="width: @(avanceCursoPorcentaje >= 100 ? 100 : avanceCursoPorcentaje)%; background-color: @(avanceCursoPorcentaje >= 100 ? "var(--mat-success)" : "var(--mat-accent)");" aria-valuenow="@avanceCursoPorcentaje" aria-valuemin="0" aria-valuemax="100"></div>
												</div>
												@if (avanceCursoPorcentaje >= 100)
												{
													<p class="small text-success fw-medium mb-0 mt-2"><i class="ri-checkbox-circle-fill me-1"></i> ¡Curso completado! Puede continuar al siguiente paso</p>
												}
												else if (avanceCursoPorcentaje > 0)
												{
													<p class="small text-muted text-center mb-0 mt-2">Debe completar el curso al 100% para continuar</p>
												}
											</div>
										}
										<div class="d-flex flex-column flex-sm-row align-items-center justify-content-center gap-3 mb-4">
											<button type="button" class="btn btn-primary mat-ethics-btn-primary" disabled="@abriendonAulaVirtual" @onclick="IrAlAulaVirtual">
												@if (abriendonAulaVirtual)
												{
													<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
													<span class="ms-2">Abriendo...</span>
												}
												else
												{
													<i class="ri-global-line me-2" aria-hidden="true"></i>
													<span>Ir al aula virtual</span>
												}
											</button>
											<button type="button" class="btn btn-outline-primary mat-ethics-btn-verify" disabled="@verificandoCurso" @onclick="VerificarCursoEticaAsync">
												@if (verificandoCurso)
												{
													<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
													<span class="ms-2">Verificando...</span>
												}
												else
												{
													<i class="ri-checkbox-circle-line me-2" aria-hidden="true"></i>
													<span>Verificar Avance</span>
												}
											</button>
										</div>
										<div class="mat-ethics-instructions rounded p-3">
											<div class="d-flex align-items-start gap-2">
												<i class="ri-information-line mat-ethics-instructions-icon" aria-hidden="true"></i>
												<div class="small">
													<p class="fw-medium mb-1">Instrucciones importantes:</p>
													<ul class="mb-0 ps-3">
														<li>El curso se genera automáticamente con sus datos de registro</li>
														<li>Debe completar todas las lecciones y aprobar las evaluaciones</li>
														<li>Una vez completado el 100%, use el botón "Verificar Avance" para continuar</li>
														<li>El progreso se guarda automáticamente en la plataforma</li>
													</ul>
												</div>
											</div>
										</div>
										@if (esAmbienteDesarrollo)
										{
											<div class="mt-3 text-center">
												<button type="button" class="btn btn-sm btn-warning" @onclick="SimularCursoCompletado"><i class="ri-test-tube-line me-1"></i> Simular Curso Completado (DEV)</button>
											</div>
										}
									</div>
								</div>
								<div class="mat-ficha-actions">
									<button type="button" class="btn btn-outline-secondary btn-lg border-2" @onclick="VolverAPaso1">
										<i class="ri-arrow-left-line me-1"></i> Volver
									</button>
									<button type="button" class="btn btn-lg @(cursoEticaCompletado ? "btn-primary" : "btn-secondary")" style="@(cursoEticaCompletado ? "background-color: var(--mat-primary); color: #fff;" : "")" disabled="@(!cursoEticaCompletado)" @onclick="() => { if (cursoEticaCompletado) currentStep = 3; }">
										<span>Siguiente</span>
										<i class="ri-check-line ms-2" aria-hidden="true"></i>
									</button>
								</div>
							}

							@* PASO 3: Formulario completo y envío *@
							@if (currentStep == 3)
							{
							<EditForm Model="@formData" OnValidSubmit="@HandleValidSubmit">
								<div class="d-flex justify-content-start mb-3">
									@if (cursoEticaCompletado)
									{
										<button type="button" class="btn btn-outline-primary" @onclick="() => currentStep = 2">
											<i class="ri-arrow-left-line"></i> Volver a Paso 2
										</button>
									}
									else
									{
										<button type="button" class="btn btn-outline-primary" @onclick="VolverAPaso1">
											<i class="ri-arrow-left-line"></i> Volver a Paso 1
										</button>
