											<div class="col-md-6 mb-2">
												<strong>Nombres:</strong>
												<div>@(formData.Nombres)</div>
											</div>
											<div class="col-md-6 mb-2">
												<strong>Apellido Paterno:</strong>
												<div>@(formData.ApellidoPaterno)</div>
											</div>
											<div class="col-md-6 mb-2">
												<strong>Apellido Materno:</strong>
												<div>@(formData.ApellidoMaterno)</div>
											</div>
