																<option value="">Seleccione una universidad</option>
																@foreach (var uni in universidades)
																{
																	<option value="@uni.Id">@uni.Nombre</option>
																}
															</InputSelect>
															<p class="small text-muted mb-0 mt-1"><i class="ri-information-line" aria-hidden="true"></i> Universidades disponibles para Perú</p>
														</div>
													</div>
												}
												else
												{
													<div class="col-md-6">
														<div class="form-group">
