												<span class="fw-semibold">S/ 1,000.00</span>
											</div>
											<div class="mat-prema-pago-summary-row">
												<span class="text-secondary">1era Cuota</span>
												<span class="fw-semibold">S/ 35.00</span>
											</div>
											<div class="mat-prema-pago-summary-total">
