									<input id="acepta_ddjj" type="checkbox" class="@( !ddjjValida && intentadoEnviar ? "is-invalid" : "")" checked="@aceptaDDJJ" @onchange="OnToggleDDJJ" disabled="@ddjjFirmada" />
									<label for="acepta_ddjj" style="cursor:pointer;" @onclick="OnLabelDDJJClick">
										Declaro bajo juramento que toda la información proporcionada es verídica y me comprometo a presentar la documentación original cuando sea requerida.
									</label>
								</div>
								@if (!ddjjValida && intentadoEnviar)
								{
									<div class="text-danger mt-1">Debe aceptar la DDJJ para continuar.</div>
								}
							}
							else
							{
								<div class="alert alert-info">
									<i class="ri-information-line me-1"></i>
									<strong>Modo de corrección:</strong> Actualice los datos observados y presione "Actualizar Solicitud".
								</div>
							}
									</div>
								</div>
								<DataAnnotationsValidator />
								<ValidationSummary />
								@if (!string.IsNullOrEmpty(mensajeError))
								{
									<div class="alert alert-danger">@mensajeError</div>
								}
								<div class="mat-prema-step3-footer">
									<button type="button" class="btn btn-outline-secondary" @onclick="@(() => { if (cursoEticaCompletado) currentStep = 2; else VolverAPaso1(); })">
										<i class="ri-arrow-left-line"></i> Volver
									</button>
									<button type="submit" class="mat-prema-step3-btn-pago" disabled="@enviando">
