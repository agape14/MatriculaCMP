		// Perfil 1: Profesional peruano con título de universidad peruana
		// Perfil 3: Profesional extranjero con título otorgado en el Perú
		if (valorPerfil == "1" || valorPerfil == "3")
		{
			// Tipo de documento: DNI (62)
			formData.TipoDocumento = "62";
			tipoDocSeleccionado = "62";

			// Origen de Universidad: Nacional
			formData.UniversidadOrigen = "1";
			await OnTipoSeleccionado("1");
		}
		// Perfil 2: Profesional peruano con título de universidad extranjera
		// Perfil 4: Profesional extranjero con título otorgado en el extranjero
		else if (valorPerfil == "2" || valorPerfil == "4")
		{
			// Tipo de documento: Carnet de Extranjería (64)
			formData.TipoDocumento = "64";
			tipoDocSeleccionado = "64";

			// Limpiar el número de documento porque ya no es DNI
			formData.NumeroDocumento = string.Empty;

			// Origen de Universidad: Extranjera
