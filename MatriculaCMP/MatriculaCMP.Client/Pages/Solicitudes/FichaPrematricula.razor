			await OnTipoSeleccionado("0");
		}

		await JS.InvokeVoidAsync("console.log", new { tag = "OnPerfilSeleccionado", perfil = valorPerfil, tipoDoc = formData.TipoDocumento, uniOrigen = formData.UniversidadOrigen });
		StateHasChanged();
	}
