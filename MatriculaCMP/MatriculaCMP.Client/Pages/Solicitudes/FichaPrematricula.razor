							@* PASO 4: Pago (diseño imagen 2 / RegistrationView: header morado, icono, resumen, mensaje verde/rojo, botones, instrucciones) *@
							@if (currentStep == 4)
							{
								<div class="card mat-prema-pago-card shadow-sm border-0 mt-3">
									<div class="mat-ficha-step-header">
										<div class="mat-ficha-step-header-icon"><i class="ri-bank-card-line" aria-hidden="true"></i></div>
