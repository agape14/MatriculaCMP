														<span class="text-muted small">Comprobante: @comprobantePago</span>
													}
												</div>
											</div>
										}
										else if (verificacionPagoFallida && !verificandoPago)
										{
											<div class="mat-prema-pago-error">
												<i class="ri-error-warning-fill" aria-hidden="true"></i>
												<div>
													<p class="mat-prema-pago-error-title">No se encontró el comprobante</p>
													<p class="mat-prema-pago-error-desc">Intente nuevamente en unos minutos o verifique que realizó el pago.</p>
												</div>
											</div>
										}

										<div class="mat-prema-pago-buttons">
											<button type="button" class="mat-prema-pago-btn-primary" disabled="@abriendoPasarela" @onclick="AbrirPasarelaPago">
												@if (abriendoPasarela)
												{
													<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
													<span>Abriendo...</span>
												}
												else
												{
													<i class="ri-bank-card-line"></i>
													<span>Ir a Pasarela de Pago</span>
												}
											</button>
											<button type="button" class="mat-prema-pago-btn-outline" disabled="@verificandoPago" @onclick="VerificarPagoAsync">
												@if (verificandoPago)
												{
													<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
													<span>Verificando...</span>
												}
												else
												{
													<i class="ri-checkbox-circle-line"></i>
													<span>Verificar Comprobante</span>
												}
											</button>
											<button type="button" class="btn btn-outline-warning btn-sm" disabled="@(simulandoPagoDev || pagoCompletado)" title="Solo desarrollo: marca pago como verificado" @onclick="SimularPagoDesarrolloAsync">
