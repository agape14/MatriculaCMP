@page "/solicitudes/seguimiento"
@using MatriculaCMP.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MatriculaCMP.Client.Helpers

@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="container-fluid py-4">
	<div class="mat-seg-breadcrumb">
		<a href="/">Inicio</a>
		<i class="ri-arrow-right-s-line" aria-hidden="true"></i>
		<span class="active">Seguimiento Trámite</span>
	</div>

	<div class="mb-4">
		<h1 class="mat-seg-title">Seguimiento Trámite</h1>
		<p class="mat-seg-subtitle">Revisa el estado actual de tu proceso de matrícula</p>
	</div>

	<div class="card border-0 shadow-sm rounded-lg">
		<div class="card-body p-4 p-md-6">
			<div class="mat-seg-search-wrap">
				<i class="ri-search-line" aria-hidden="true"></i>
				<input type="text" placeholder="Buscar por nombre, número de solicitud..." @oninput="OnSearchInput" />
			</div>

			<div class="mat-seg-table-wrap">
				<table id="tblListadoSolicitante" class="mat-seg-table table align-middle" data-page-length="5" role="grid">
					<thead>
						<tr>
							<th>Nombre</th>
							<th>N° Solicitud</th>
							<th class="d-none d-md-table-cell">Fecha Solicitud</th>
							<th>Estado</th>
							<th class="d-none d-lg-table-cell">Área</th>
							<th>Observaciones</th>
							<th class="text-center">Acciones</th>
						</tr>
					</thead>
					<tbody>
						@if (solicitudes != null && solicitudes.Count > 0)
						{
							foreach (var s in solicitudes)
							{
								<tr role="row">
									<td class="fw-medium">@s.PersonaNombre</td>
									<td>@s.NumeroSolicitud.ToString("D8")</td>
									<td class="d-none d-md-table-cell">@s.FechaSolicitud.ToString("dd/MM/yyyy")</td>
									<td>
										<span class="mat-seg-badge-estado">@s.Estado</span>
									</td>
									<td class="d-none d-lg-table-cell">@(s.AreaNombre ?? "-")</td>
									<td>@(s.Observaciones ?? "-")</td>
									<td>
										<button type="button" class="mat-seg-btn-action" disabled="@loadingVer.Contains(s.Id)" @onclick="@(() => VerDetalle(s))">
											@if (loadingVer.Contains(s.Id)) { <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> } else { <i class="ri-eye-line"></i> }
											Ver
										</button>
										<button type="button" class="mat-seg-btn-action" disabled="@loadingHistorial.Contains(s.Id)" @onclick="@(() => VerHistorialAsync(s))">
											@if (loadingHistorial.Contains(s.Id)) { <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> } else { <i class="ri-history-line"></i> }
											Historial
										</button>
										@if (s.EstadoId == 3 || s.EstadoId == 5 || s.EstadoId == 7)
										{
											<button type="button" class="mat-seg-btn-action" disabled="@loadingEditar.Contains(s.Id)" @onclick="@(() => EditarSolicitudAsync(s.Id))">
												@if (loadingEditar.Contains(s.Id)) { <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> } else { <i class="ri-edit-line"></i> }
												Editar
											</button>
											<button type="button" class="mat-seg-btn-action" disabled="@loadingReenviar.Contains(s.Id)" @onclick="@(() => ReenviarSolicitud(s.Id))">
												@if (loadingReenviar.Contains(s.Id)) { <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> } else { <i class="ri-send-plane-line"></i> }
												Reenviar
											</button>
										}
									</td>
								</tr>
							}
						}
						else
						{
							<tr>
								<td colspan="7" class="text-center py-4 text-muted">No se encontraron solicitudes</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
                   
                    <!-- Modal Loading -->
                    <div class="modal fade" id="loadingModal" tabindex="-1" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content text-center p-4">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Cargando...</span>
                                </div>
                                <p class="mt-3">Descargando Formato...</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
    </div>

@* Modal Detalle (estilo TrackingView: avatar, estado azul, secciones morado) *@
@if (solicitudSeleccionada != null && !mostrarHistorialModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1050;" id="detalleModal">
        <div class="modal-dialog modal-dialog-scrollable mx-auto mat-seg-modal-content">
            <div class="modal-content border-0">
                <div class="modal-header border-0 pb-0 mat-seg-modal-header">
                    <div class="mat-seg-modal-header-block w-100">
                        <div class="mat-seg-modal-avatar-wrap">
                            @if (!string.IsNullOrEmpty(solicitudSeleccionada.Persona?.FotoPath))
                            {
                                <img src="/api/personaseducacion/fotos-medicos/@solicitudSeleccionada.Persona.FotoPath" alt="@solicitudSeleccionada.Persona?.NombresCompletos" class="mat-seg-modal-avatar" />
                            }
                            else
                            {
                                <div class="mat-seg-modal-avatar bg-light d-flex align-items-center justify-content-center"><i class="ri-user-line text-muted" style="font-size: 2rem;"></i></div>
                            }
                            <span class="mat-seg-modal-avatar-dot" aria-hidden="true"></span>
                        </div>
                        <div class="flex-grow-1">
                            <h2 class="mat-seg-modal-title">Detalles de Solicitud</h2>
                            <p class="mat-seg-modal-desc">N° @solicitudSeleccionada.NumeroSolicitud.ToString("D8") - @solicitudSeleccionada.FechaSolicitud.ToString("dd/MM/yyyy")</p>
                            <p class="mat-seg-modal-name">@(solicitudSeleccionada.Persona?.NombresCompletos?.ToUpperInvariant() ?? "")</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close position-absolute" style="top: 1rem; right: 1rem;" @onclick="CerrarModales" aria-label="Cerrar"></button>
                </div>

                <div class="mat-seg-modal-scroll">
                <div class="mat-seg-estado-actual">
                    <i class="ri-shield-check-line" aria-hidden="true"></i>
                    <div>
                        <p class="titulo">Estado Actual</p>
                        <p class="valor">@(solicitudSeleccionada.EstadoSolicitud?.Nombre ?? solicitudSeleccionada.Observaciones ?? "—")</p>
                    </div>
                </div>

                <div class="mat-seg-modal-body">
                    <div class="mat-seg-modal-section card border-0 overflow-hidden">
                        <div class="mat-ficha-step-header">
                            <div class="mat-ficha-step-header-icon"><i class="ri-user-line" aria-hidden="true"></i></div>
                            <h3 class="mat-ficha-step-header-title mb-0">Datos Personales</h3>
                        </div>
                        <div class="mat-seg-section-body">
                            <div class="row">
                                <div class="col-md-4 mb-3 text-center text-md-start">
                                    @if (!string.IsNullOrEmpty(solicitudSeleccionada.Persona?.FotoPath))
                                    {
                                        <img src="/api/personaseducacion/fotos-medicos/@solicitudSeleccionada.Persona.FotoPath" alt="Foto" class="mat-seg-foto-pasaporte" />
                                    }
                                    else
                                    {
                                        <div class="mat-seg-foto-pasaporte bg-light d-flex align-items-center justify-content-center mx-auto"><i class="ri-user-line text-muted" style="font-size: 2.5rem;"></i></div>
                                    }
                                    <p class="small text-muted mt-1 mb-0">Foto tamaño pasaporte</p>
                                </div>
                                <div class="col-md-8">
                                    <div class="row g-3">
                                        <div class="col-sm-6"><p class="mat-seg-label mb-0">Nombre Completo</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.NombresCompletos?.ToUpperInvariant() ?? "-")</p></div>
                                        <div class="col-sm-6"><p class="mat-seg-label mb-0">DNI / Documento</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.NumeroDocumento ?? "-")</p></div>
                                        <div class="col-sm-6"><p class="mat-seg-label mb-0">Correo Electrónico</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.Email ?? "-")</p></div>
                                        <div class="col-sm-6"><p class="mat-seg-label mb-0">Teléfono</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.Celular ?? "-")</p></div>
                                        <div class="col-sm-6"><p class="mat-seg-label mb-0">Fecha de Nacimiento</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "-")</p></div>
                                        <div class="col-sm-6"><p class="mat-seg-label mb-0">Grupo Sanguíneo</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.GrupoSanguineo?.Nombre ?? "-")</p></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mat-seg-modal-section card border-0 overflow-hidden">
                        <div class="mat-ficha-step-header">
                            <div class="mat-ficha-step-header-icon"><i class="ri-graduation-cap-line" aria-hidden="true"></i></div>
                            <h3 class="mat-ficha-step-header-title mb-0">Información Académica</h3>
                        </div>
                        <div class="mat-seg-section-body">
                            <div class="row g-3">
                                <div class="col-sm-6"><p class="mat-seg-label mb-0">Universidad de Origen</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.Educaciones?.FirstOrDefault()?.Universidad?.Nombre ?? "-")</p></div>
                                <div class="col-sm-6"><p class="mat-seg-label mb-0">Fecha de Emisión del Título</p><p class="mat-seg-value mb-0">@(solicitudSeleccionada.Persona?.Educaciones?.FirstOrDefault()?.FechaEmisionTitulo.ToString("dd/MM/yyyy") ?? "-")</p></div>
                                <div class="col-sm-6"><p class="mat-seg-label mb-0">Consejo Regional</p><p class="mat-seg-value mb-0">@(consejos.FirstOrDefault(c => c.ConsejoRegional_Key.ToString() == solicitudSeleccionada.Persona?.ConsejoRegionalId)?.Nombre ?? "-")</p></div>
                            </div>
                        </div>
                    </div>

                    <div class="mat-seg-modal-section card border-0 overflow-hidden">
                        <div class="mat-ficha-step-header">
                            <div class="mat-ficha-step-header-icon"><i class="ri-file-text-line" aria-hidden="true"></i></div>
                            <h3 class="mat-ficha-step-header-title mb-0">Documentos Adjuntos</h3>
                        </div>
                        <div class="mat-seg-section-body">
                            @if (solicitudSeleccionada?.Persona?.Educaciones?.Any() == true)
                            {
                                var eduDet = solicitudSeleccionada.Persona.Educaciones.FirstOrDefault(e => e.Documento != null);
                                if (eduDet?.Documento != null)
                                {
                                    var docs = new Dictionary<string, string?> {
                                        { "Título Médico Cirujano", eduDet.Documento.TituloMedicoCirujanoPath },
                                        { "Constancia SUNEDU", eduDet.Documento.ConstanciaInscripcionSuneduPath },
                                        { "Antecedentes Penales", eduDet.Documento.CertificadoAntecedentesPenalesPath },
                                        { "Carnet de Extranjería", eduDet.Documento.CarnetExtranjeriaPath },
                                        { "Inscripción Reconocimiento SUNEDU", eduDet.Documento.ConstanciaInscripcionReconocimientoSuneduPath },
                                        { "Inscripción Revalidación Universidad Nacional", eduDet.Documento.ConstanciaInscripcionRevalidacionUniversidadNacionalPath },
                                        { "Reconocimiento SUNEDU", eduDet.Documento.ReconocimientoSuneduPath },
                                        { "Revalidación Universidad Nacional", eduDet.Documento.RevalidacionUniversidadNacionalPath }
                                    };
                                    @foreach (var doc in docs.Where(d => !string.IsNullOrEmpty(d.Value)))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-primary me-2 mb-2" @onclick="() => VerPdf(doc.Value!, doc.Key)"><i class="ri-file-pdf-line me-1"></i> Ver @doc.Key</button>
                                    }
                                }
                                else
                                {
                                    <p class="text-muted mb-0">No hay documentos registrados.</p>
                                }
                            }
                            else
                            {
                                <p class="text-muted mb-0">Sin información de educación registrada.</p>
                            }
                        </div>
                    </div>

                    <div class="mat-seg-modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModales"><i class="ri-close-line me-1"></i> Cerrar</button>
                    </div>
                </div>
                </div>
            </div>
        </div>
    </div>
}

@* Modal Historial (timeline con HistorialEstados) *@
@if (solicitudSeleccionada != null && mostrarHistorialModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-dialog-scrollable mx-auto mat-seg-modal-content">
            <div class="modal-content border-0">
                <div class="modal-header border-0 pb-0 mat-seg-modal-header">
                    <div class="mat-seg-modal-header-block w-100">
                        <div class="mat-seg-modal-avatar-wrap">
                            @if (!string.IsNullOrEmpty(solicitudSeleccionada.Persona?.FotoPath))
                            {
                                <img src="/api/personaseducacion/fotos-medicos/@solicitudSeleccionada.Persona.FotoPath" alt="@solicitudSeleccionada.Persona?.NombresCompletos" class="mat-seg-modal-avatar" />
                            }
                            else
                            {
                                <div class="mat-seg-modal-avatar bg-light d-flex align-items-center justify-content-center"><i class="ri-user-line text-muted" style="font-size: 2rem;"></i></div>
                            }
                            <span class="mat-seg-modal-avatar-dot" aria-hidden="true"></span>
                        </div>
                        <div class="flex-grow-1">
                            <h2 class="mat-seg-modal-title">Historial de Solicitud</h2>
                            <p class="mat-seg-modal-desc">N° @solicitudSeleccionada.NumeroSolicitud.ToString("D8") - @solicitudSeleccionada.FechaSolicitud.ToString("dd/MM/yyyy")</p>
                            <p class="mat-seg-modal-name">@(solicitudSeleccionada.Persona?.NombresCompletos?.ToUpperInvariant() ?? "")</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close position-absolute" style="top: 1rem; right: 1rem;" @onclick="CerrarModales" aria-label="Cerrar"></button>
                </div>

                <div class="mat-seg-modal-scroll">
                <div class="mat-seg-estado-actual">
                    <i class="ri-shield-check-line" aria-hidden="true"></i>
                    <div>
                        <p class="titulo">Estado Actual</p>
                        <p class="valor">@(solicitudSeleccionada.EstadoSolicitud?.Nombre ?? "—")</p>
                    </div>
                </div>

                <div class="mat-seg-modal-body">
                    <div class="mat-seg-modal-section card border-0 overflow-hidden">
                        <div class="mat-ficha-step-header">
                            <div class="mat-ficha-step-header-icon"><i class="ri-history-line" aria-hidden="true"></i></div>
                            <h3 class="mat-ficha-step-header-title mb-0">Historial de Eventos</h3>
                        </div>
                        <div class="mat-seg-section-body p-4">
                            @if (solicitudSeleccionada.HistorialEstados?.Any() == true)
                            {
                                var eventos = solicitudSeleccionada.HistorialEstados.OrderBy(h => h.FechaCambio).ToList();
                                <div class="mat-seg-timeline">
                                    <div class="mat-seg-timeline-line" aria-hidden="true"></div>
                                    @for (var i = 0; i < eventos.Count; i++)
                                    {
                                        var ev = eventos[i];
                                        var esUltimo = i == eventos.Count - 1;
                                        <div class="mat-seg-timeline-item">
                                            <div class="mat-seg-timeline-icon @(esUltimo ? "pendiente" : "completado")">
                                                @if (esUltimo)
                                                {
                                                    <i class="ri-time-line" aria-hidden="true"></i>
                                                }
                                                else
                                                {
                                                    <i class="ri-check-line" aria-hidden="true"></i>
                                                }
                                            </div>
                                            <div class="mat-seg-timeline-card @(esUltimo ? "pendiente" : "completado")">
                                                <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                                    <h4 class="mb-0">@(ev.EstadoNuevo?.Nombre ?? "Sin estado")</h4>
                                                    <span class="mat-seg-timeline-badge @(esUltimo ? "pendiente" : "completado")">@(esUltimo ? "En Proceso" : "Completado")</span>
                                                </div>
                                                <div class="mat-seg-timeline-meta mt-2">
                                                    <span><i class="ri-calendar-line"></i> @ev.FechaCambio.ToString("dd/MM/yyyy")</span>
                                                    <span><i class="ri-time-line"></i> @ev.FechaCambio.ToString("hh:mm tt")</span>
                                                    @if (!string.IsNullOrEmpty(ev.UsuarioCambio))
                                                    {
                                                        <span><i class="ri-user-line"></i> @ev.UsuarioCambio</span>
                                                    }
                                                    @if (solicitudSeleccionada.Area != null)
                                                    {
                                                        <span><i class="ri-map-pin-line"></i> @(solicitudSeleccionada.Area.Nombre ?? "")</span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(ev.Observacion))
                                                {
                                                    <p class="small mb-0 mt-2 text-muted">@ev.Observacion</p>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">No hay historial disponible.</p>
                            }
                        </div>
                    </div>

                    <div class="mat-seg-modal-footer">
                        <button type="button" class="btn btn-outline-secondary" @onclick="CerrarModales"><i class="ri-close-line me-1"></i> Cerrar</button>
                    </div>
                </div>
                </div>
            </div>
        </div>
    </div>
}
@if (mostrarVisorPdf && !string.IsNullOrEmpty(pdfUrl))
{
    <div class="modal fade show d-block" style="background-color: rgba(0, 0, 0, 0.8); z-index: 1055;">
        <div class="modal-dialog modal-xl">
            <div class="modal-content" style="height: 100vh; border-radius: 0;">
                <div class="modal-header bg-morado text-white">
                    <h5 class="modal-title text-white ">@nombrePDF</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarVisorPdf"></button>
                </div>
                <div class="modal-body p-0" style="height: calc(100vh - 56px);">
                    <iframe src="@pdfUrl" width="100%" height="100%" style="border: none;"></iframe>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool seleccionarTodos = false;
    private List<PersonaConEducacionDto> personas = new();
    private List<SolicitudSeguimientoDto> solicitudes = new();
    private Solicitud? solicitudSeleccionada = null;
    private bool mostrarHistorialModal = false;
    private string personaId = "";
    private string? pdfUrl;
    private bool mostrarVisorPdf = false;
    private string nombrePDF = "";
    private List<Mat_ConsejoRegional> consejos = new();
    private HashSet<int> loadingVer = new();
    private HashSet<int> loadingHistorial = new();
    private HashSet<int> loadingEditar = new();
    private HashSet<int> loadingReenviar = new();

    private void CerrarModales()
    {
        solicitudSeleccionada = null;
        mostrarHistorialModal = false;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            personaId = user.FindFirst("PersonaId").Value ?? "0";
        }

        // personas = await Http.GetFromJsonAsync<List<PersonaConEducacionDto>>("api/personaseducacion/con-educacion");
        // solicitudes = await Http.GetFromJsonAsync<List<SolicitudSeguimientoDto>>($"api/personaseducacion/mis-solicitudes/{personaId}");
        // await InvokeAsync(StateHasChanged); // Forzar un re-renderizado

        if (!int.TryParse(personaId, out int personaIdInt))
        {
            Console.WriteLine("PersonaId inválido en claims aa.");
            return;
        }
        consejos = await Http.GetFromJsonAsync<List<Mat_ConsejoRegional>>("api/consejoregional");
        await CargarSolicitudes(personaIdInt);
    }

    
    private async Task CargarSolicitudes(int personaIdInt)
    {
        try
        {
            solicitudes = await Http.GetFromJsonAsync<List<SolicitudSeguimientoDto>>(
                $"api/personaseducacion/mis-solicitudes/{personaIdInt}");
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"Error en solicitud HTTP: {ex.Message}");
            // Aquí puedes manejar el error o mostrar mensaje en pantalla
        }
    }
    private async Task VerDetalle(SolicitudSeguimientoDto solicitud)
    {
        try
        {
            mostrarHistorialModal = false;
            loadingVer.Add(solicitud.Id);
            StateHasChanged();
            solicitudSeleccionada = await Http.GetFromJsonAsync<Solicitud>($"api/personaseducacion/solicituddet/{solicitud.Id}");
        }
        finally
        {
            loadingVer.Remove(solicitud.Id);
            StateHasChanged();
        }
    }
    private async Task EditarSolicitudAsync(int solicitudId)
    {
        try
        {
            loadingEditar.Add(solicitudId);
            StateHasChanged();
            await Task.Delay(10);
            Nav.NavigateTo($"/solicitudes/prematricula/{solicitudId}");
        }
        finally
        {
            loadingEditar.Remove(solicitudId);
        }
    }

    private async Task VerHistorialAsync(SolicitudSeguimientoDto solicitud)
    {
        try
        {
            loadingHistorial.Add(solicitud.Id);
            StateHasChanged();
            solicitudSeleccionada = await Http.GetFromJsonAsync<Solicitud>($"api/personaseducacion/solicituddet/{solicitud.Id}");
            mostrarHistorialModal = true;
        }
        finally
        {
            loadingHistorial.Remove(solicitud.Id);
            StateHasChanged();
        }
    }

    private async Task ReenviarSolicitud(int solicitudId)
    {
        loadingReenviar.Add(solicitudId);
        StateHasChanged();
        var confirmar = await JS.InvokeAsync<bool>("confirmarSweet",
            "¿Está seguro de reenviar esta solicitud?",
            "La solicitud será enviada nuevamente al área correspondiente para revisión.");

        if (!confirmar)
        {
            loadingReenviar.Remove(solicitudId);
            StateHasChanged();
            return;
        }

        try
        {
            var response = await Http.PostAsync($"api/correccionsolicitud/reenviar-solicitud/{solicitudId}", null);
            
            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("Swal.fire", "Éxito", "Solicitud reenviada exitosamente", "success");
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                var personaClaim = user.FindFirst("PersonaId")?.Value ?? "0";
                if (int.TryParse(personaClaim, out var personaIdInt))
                {
                    await CargarSolicitudes(personaIdInt);
                }
            }
            else
            {
                var errorMessage = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("Swal.fire", "Error", errorMessage, "error");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("Swal.fire", "Error", $"Error al reenviar la solicitud: {ex.Message}", "error");
        }
        finally
        {
            loadingReenviar.Remove(solicitudId);
            StateHasChanged();
        }
    }
    private string GetBadgeColor(string estado)
    {
        return estado switch
        {
            "Registrado" => "primary",
            "Aprobado" => "success",
            "Rechazado" => "danger",
            "Observado" => "warning",
            _ => "secondary"
        };
    }
