@using MatriculaCMP.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="mat-layout @(sidebarCollapsed ? "sidebar-collapsed" : "")">
    <!-- Backdrop móvil: al hacer clic cierra el sidebar -->
    <div class="mat-sidebar-backdrop @(mobileSidebarOpen ? "show" : "")"
         @onclick="ToggleMobileSidebar"
         aria-hidden="true"></div>

    <!-- Sidebar: mismo contenido en desktop y móvil -->
    <aside class="mat-sidebar @(sidebarCollapsed ? "collapsed" : "") @(mobileSidebarOpen ? "show" : "")" id="matSidebar">
        <NavMenu Collapsed="@sidebarCollapsed" />
    </aside>

    <div class="mat-main-wrapper flex-grow-1 d-flex flex-column min-vh-100">
        <header class="mat-topbar">
            <div class="mat-topbar-left">
                <button type="button" class="mat-btn-toggle-sidebar d-md-none" @onclick="ToggleMobileSidebar"
                        aria-label="Abrir o cerrar menú">
                    <i class="ri-menu-line"></i>
                </button>
                <button type="button" class="mat-btn-toggle-sidebar d-none d-md-inline-flex" @onclick="ToggleSidebarCollapsed"
                        aria-label="Colapsar o expandir menú" title="@(sidebarCollapsed ? "Expandir menú" : "Colapsar menú")">
                    <i class="ri-layout-left-line"></i>
                </button>
                <div class="mat-topbar-user d-flex align-items-center min-width-0">
                    <i class="ri-user-heart-line mat-topbar-user-icon" aria-hidden="true"></i>
                    <span class="text-truncate">@nombresCompletos</span>
                </div>
                <div class="mat-topbar-role d-none d-sm-flex align-items-center">
                    <i class="ri-map-pin-line mat-topbar-role-icon" aria-hidden="true"></i>
                    <span class="text-truncate">@nombrePerfil</span>
                </div>
            </div>
            <div class="mat-topbar-actions">
                <button type="button" class="mat-btn-logout" @onclick="Salir" title="Cerrar sesión">
                    <i class="ri-logout-box-r-line" aria-hidden="true"></i>
                    <span class="d-none d-sm-inline">Cerrar Sesión</span>
                </button>
            </div>
        </header>

        <main class="mat-main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    Se ha producido un error no manejado.
    <a href="" class="reload">Recargar Página</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private string nombresCompletos = "";
    private string nombrePerfil = "";
    private string perfilUsuario = "";
    private bool sidebarCollapsed;
    private bool mobileSidebarOpen;
    private bool jsReady;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                nombresCompletos = user.FindFirst("NombresCompletos")?.Value ?? "-";
                nombrePerfil = user.FindFirst("PerfilNombre")?.Value ?? "-";
                perfilUsuario = user.FindFirst("PerfilId")?.Value ?? "1";
            }
            else
            {
                perfilUsuario = "1";
            }
        }
        catch
        {
            perfilUsuario = "1";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !jsReady)
        {
            try
            {
                sidebarCollapsed = await JS.InvokeAsync<bool>("eval", "localStorage.getItem('matriculaCMP_sidebar_collapsed') === '1'");
                jsReady = true;
                StateHasChanged();
            }
            catch { }
        }
    }

    private void ToggleMobileSidebar()
    {
        mobileSidebarOpen = !mobileSidebarOpen;
    }

    private async Task ToggleSidebarCollapsed()
    {
        sidebarCollapsed = !sidebarCollapsed;
        try
        {
            await JS.InvokeVoidAsync("eval", $"localStorage.setItem('matriculaCMP_sidebar_collapsed', '{ (sidebarCollapsed ? "1" : "") }')");
        }
        catch { }
    }

    private async Task Salir()
    {
        var result = await JS.InvokeAsync<bool>("confirmarCerrarSesion");
        if (result)
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "Token");
            await AuthenticationStateProvider.GetAuthenticationStateAsync();
            Navigation.NavigateTo("/", true);
        }
    }
}
