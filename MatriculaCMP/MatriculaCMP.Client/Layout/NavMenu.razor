@using MatriculaCMP.Client.Layout
@using MatriculaCMP.Client.Services
@using MatriculaCMP.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using Microsoft.JSInterop
@using System.Text.Json
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject HttpClient Http
@inject MenuCacheService MenuCache

<!-- Brand/Logo (diseño React: icono + texto) -->
<div class="mat-sidebar-brand">
    <a href="/home" class="d-flex align-items-center gap-2">
        <span class="mat-sidebar-brand-icon">
            <i class="ri-home-5-line" aria-hidden="true"></i>
        </span>
        <span class="mat-sidebar-brand-text">MatriculaCMP</span>
    </a>
</div>

<div class="mat-sidebar-nav">
    <nav class="d-flex flex-column">
        <!-- Inicio fijo -->
        <div class="mat-nav-item">
            <NavLink class="mat-nav-link" href="/home" Match="NavLinkMatch.All" ActiveClass="active">
                <i class="ri-home-line" aria-hidden="true"></i>
                <span>Inicio</span>
            </NavLink>
        </div>

        @if (menusAgrupados?.Count > 0)
        {
            @foreach (var kvp in menusAgrupados.OrderBy(k => k.Value.MinId))
            {
                <div class="mat-nav-section">
                    <i class="@(string.IsNullOrWhiteSpace(kvp.Value.ModuloIcono) ? ObtenerIconoPorDefecto(kvp.Key) : kvp.Value.ModuloIcono)" aria-hidden="true"></i>
                    <span class="mat-nav-section-label">@kvp.Key</span>
                </div>
                @foreach (var m in kvp.Value.Items.OrderBy(i => i.Orden ?? int.MaxValue).ThenBy(i => i.Id))
                {
                    <div class="mat-nav-item">
                        <NavLink class="mat-nav-link" href="@m.Ruta" ActiveClass="active">
                            <i class="@m.Icono" aria-hidden="true"></i>
                            <span>@m.Titulo</span>
                        </NavLink>
                    </div>
                }
            }
        }
        else if (mostrandoCargandoMenu)
        {
            <div class="mat-nav-item text-white-50 small px-3 py-2">
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                Cargando menú...
            </div>
        }
    </nav>
</div>
@code {
    [Parameter]
    public bool Collapsed { get; set; }

    private string perfilUsuario = "";
    private record GrupoMenu(string? ModuloIcono, List<Menu> Items, int MinId);
    private Dictionary<string, GrupoMenu> menusAgrupados = new();
    private DotNetObjectReference<NavMenu>? _dotNetRef;
    private bool mostrandoCargandoMenu = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated ?? false)
            {
                perfilUsuario = user.FindFirst("PerfilId")?.Value ?? "1";
                var perfilId = int.TryParse(perfilUsuario, out var pid) ? pid : 0;
                if (perfilId > 0)
                {
                    var cached = MenuCache.GetCached(perfilId);
                    if (cached != null && cached.Count > 0)
                    {
                        menusAgrupados = ConstruirMenusAgrupados(cached);
                        StateHasChanged();
                    }
                    else
                    {
                        try
                        {
                            var json = await JS.InvokeAsync<string>("cmpGetMenuStorage", perfilId);
                            if (!string.IsNullOrWhiteSpace(json))
                            {
                                var list = JsonSerializer.Deserialize<List<Menu>>(json);
                                if (list?.Count > 0)
                                {
                                    MenuCache.SetCached(perfilId, list);
                                    menusAgrupados = ConstruirMenusAgrupados(list);
                                    StateHasChanged();
                                }
                            }
                        }
                        catch { /* en servidor/SSR no hay localStorage */ }
                        if (menusAgrupados.Count == 0)
                            mostrandoCargandoMenu = true;
                    }
                }
                await CargarMenus();
                mostrandoCargandoMenu = false;
                StateHasChanged();
            }
            else
            {
                perfilUsuario = "1"; // Default fallback
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando perfil de usuario: {ex.Message}");
            perfilUsuario = "1"; // Default fallback
        }
        // Suscribirse a cambios para auto-refresco inter-páginas (simple)
        try
        {
            await JS.InvokeVoidAsync("eval", @"(function(){
                if (window.__cmpNavMenuListener) return;
                window.__cmpNavMenuListener = true;
                window.addEventListener('storage', function(e){
                    if (e && e.key === 'cmp-refresh-nav') {
                        // Señal de refresco de menú
                        DotNet.invokeMethodAsync('MatriculaCMP.Client', 'Dummy');
                    }
                });
            })();");
        }
        catch {}
    }

    private static Dictionary<string, GrupoMenu> ConstruirMenusAgrupados(List<Menu> menus)
    {
        return menus
            .GroupBy(m => string.IsNullOrWhiteSpace(m.Modulo) ? "General" : m.Modulo)
            .ToDictionary(
                g => g.Key,
                g => new GrupoMenu(
                    g.FirstOrDefault(m => !string.IsNullOrWhiteSpace(m.ModuloIcono))?.ModuloIcono,
                    g.OrderBy(x => x.Titulo).ToList(),
                    g.Min(x => x.Id)
                )
            );
    }

    private async Task CargarMenus()
    {
        try
        {
            var perfilId = int.TryParse(perfilUsuario, out var pid) ? pid : 0;
            if (perfilId <= 0) return;
            var menus = await Http.GetFromJsonAsync<List<Menu>>($"api/menu/por-perfil/{perfilId}") ?? new List<Menu>();
            
            // Si es administrador (perfilId == 1), filtrar menús del módulo SOLICITANTE
            if (perfilId == 1)
            {
                menus = menus.Where(m => 
                    string.IsNullOrWhiteSpace(m.Modulo) || 
                    !m.Modulo.Trim().Equals("SOLICITANTE", StringComparison.OrdinalIgnoreCase)
                ).ToList();
            }
            
            // Filtrar menú /consejoregional/lista para todos los perfiles (ya no se usa)
            menus = menus.Where(m => 
                string.IsNullOrWhiteSpace(m.Ruta) || 
                !m.Ruta.Trim().Equals("/consejoregional/lista", StringComparison.OrdinalIgnoreCase)
            ).ToList();
            
            menusAgrupados = ConstruirMenusAgrupados(menus);
            MenuCache.SetCached(perfilId, menus);
            try
            {
                await JS.InvokeVoidAsync("cmpSetMenuStorage", perfilId, JsonSerializer.Serialize(menus));
            }
            catch { /* ignorar fallo de localStorage */ }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando menús dinámicos: {ex.Message}");
        }
    }

    private string ObtenerIconoPorDefecto(string modulo)
    {
        var key = (modulo ?? "").Trim().ToUpperInvariant();
        return key switch
        {
            "CR" or "CONSEJO REGIONAL" => "ri-government-line",
            "SG" or "SECRETARIA GENERAL" or "SECRETARÍA GENERAL" => "ri-shield-star-line",
            "OM" or "OFICINA MATRICULA" or "OFICINA MATRÍCULA" => "ri-building-line",
            "DECANATO" => "ri-award-line",
            "ADMIN" or "ADMINISTRACION" or "ADMINISTRACIÓN" or "ADMINISTRADOR" => "ri-settings-3-line",
            _ => "ri-folder-2-line"
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("eval", @"(function(){
                    window.cmpRegisterNav = function(dotnet){
                        if (window.__cmpNavMenuListener) return;
                        window.__cmpNavMenuListener = true;
                        window.addEventListener('storage', function(e){
                            if (e && e.key === 'cmp-refresh-nav') {
                                try{ dotnet.invokeMethodAsync('RefreshMenus'); }catch(_){ }
                            }
                        });
                    }
                })();");
                await JS.InvokeVoidAsync("cmpRegisterNav", _dotNetRef);
            }
            catch { }
            // En el cliente, si el menú sigue vacío, intentar de nuevo desde localStorage (por si vino de SSR sin datos)
            var perfilId = int.TryParse(perfilUsuario, out var pid) ? pid : 0;
            if (perfilId > 0 && (menusAgrupados == null || menusAgrupados.Count == 0))
            {
                try
                {
                    var json = await JS.InvokeAsync<string>("cmpGetMenuStorage", perfilId);
                    if (!string.IsNullOrWhiteSpace(json))
                    {
                        var list = JsonSerializer.Deserialize<List<Menu>>(json);
                        if (list?.Count > 0)
                        {
                            MenuCache.SetCached(perfilId, list);
                            menusAgrupados = ConstruirMenusAgrupados(list);
                            mostrandoCargandoMenu = false;
                            await InvokeAsync(StateHasChanged);
                        }
                    }
                }
                catch { }
            }
        }
    }

    [JSInvokable]
    public async Task RefreshMenus()
    {
        await CargarMenus();
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}